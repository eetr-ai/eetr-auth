{
	"name": "progression-ai-auth",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:migrate": "wrangler d1 execute progression-ai-auth --local --file=./db/schema.sql",
		"db:migrate:remote": "wrangler d1 execute progression-ai-auth --remote --file=./db/schema.sql",
		"db:bootstrap": "npm run db:migrate && npm run db:migrate:remote",
		"db:create-admin": "node scripts/create-admin.mjs",
		"db:create-admin:local": "node scripts/create-admin.mjs --local-only",
		"db:create-admin:remote": "node scripts/create-admin.mjs --remote-only",
		"db:create-user": "npm run db:create-admin",
		"db:create-user:local": "npm run db:create-admin:local",
		"db:create-user:remote": "npm run db:create-admin:remote",
		"jwt:setup-secrets": "node scripts/setup-jwt-secrets.mjs",
		"jwt:generate-local-cert": "node scripts/generate-local-jwt-cert.mjs"
	},
	"dependencies": {
		"@eetr/react-reducer-utils": "^0.1.1",
		"@opennextjs/cloudflare": "^1.17.1",
		"jose": "^6.0.11",
		"lucide-react": "^0.576.0",
		"md5": "^2.3.0",
		"next": "16.1.5",
		"next-auth": "^5.0.0-beta.30",
		"react": "19.1.5",
		"react-dom": "19.1.5"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20.19.35",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.69.0"
	}
}
