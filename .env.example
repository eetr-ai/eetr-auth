# Auth.js (next-auth). Required for session encryption.
# Generate with: npx auth secret
AUTH_SECRET=

# JWT (local dev): run npm run jwt:generate-local-cert to set JWT_PRIVATE_KEY in .env.local
# and write .tmp/jwks.json. Then: npx wrangler r2 object put blog-images/jwks.json --file=.tmp/jwks.json --local
