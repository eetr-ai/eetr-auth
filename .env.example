# Auth.js (next-auth). Required for session encryption.
# Generate with: npx auth secret
AUTH_SECRET=

# JWT (local dev): run npm run jwt:generate-local-cert to set JWT_PRIVATE_KEY, JWT_KID, and JWT_JWKS_JSON
# in .env.local. Verification uses JWT_JWKS_JSON so next dev works (R2 in next dev is separate from wrangler --local).
