{
  "name": "@eetr/eetr-auth-client",
  "version": "0.2.0",
  "description": "TypeScript client library for eetr-auth OAuth 2.1 / OIDC server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "@types/node": "^20.19.35",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
