{
	"name": "@eetr/auth",
	"version": "0.2.0",
	"description": "OAuth 2.1 and OpenID Connect authorization server for Cloudflare Workers",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "next lint",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"setup:local:env": "node scripts/setup-local-dev.mjs",
		"setup:local": "npm run setup:local:env && npm run db:schema && npm run db:seed-local-admin",
		"setup:remote": "node scripts/setup-remote.mjs",
		"upgrade:remote": "node scripts/upgrade-remote.mjs",
		"deploy": "opennextjs-cloudflare build && SKIP_WRANGLER_CONFIG_CHECK=yes opennextjs-cloudflare deploy -c wrangler.generated.jsonc -- --skipWranglerConfigCheck",
		"deploy:infra": "npm run deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:schema": "node scripts/run-d1-migrate.mjs --local --file=db/schema.sql",
		"db:schema:remote": "node scripts/run-d1-migrate.mjs --remote --file=db/schema.sql",
		"db:migrate": "node scripts/run-d1-migrate.mjs --local",
		"db:migrate:remote": "node scripts/run-d1-migrate.mjs --remote",
		"db:bootstrap": "npm run db:schema && npm run db:schema:remote",
		"db:create-admin": "node scripts/create-admin.mjs",
		"db:create-admin:local": "node scripts/create-admin.mjs --local-only",
		"db:create-admin:remote": "node scripts/create-admin.mjs --remote-only",
		"db:set-site-url": "node scripts/set-site-url.mjs",
		"db:set-site-url:local": "node scripts/set-site-url.mjs --local-only",
		"db:set-site-url:remote": "node scripts/set-site-url.mjs --remote-only",
		"db:create-user": "npm run db:create-admin --",
		"db:create-user:local": "npm run db:create-admin:local --",
		"db:create-user:remote": "npm run db:create-admin:remote --",
		"db:seed-local-admin": "node scripts/seed-local-admin.mjs",
		"db:seed-remote-admin": "node scripts/seed-remote-admin.mjs",
		"setup:hmac-key": "bash scripts/setup-hmac-key.sh",
		"jwt:setup-secrets": "node scripts/setup-jwt-secrets.mjs",
		"jwt:generate-local-cert": "node scripts/generate-local-jwt-cert.mjs",
		"infra:prepare-config": "npm run infra:terraform-output && npm run infra:render-wrangler",
		"infra:validate:setup": "node scripts/validate-remote-setup.mjs --mode clean-install",
		"infra:validate:upgrade": "node scripts/validate-remote-setup.mjs --mode upgrade",
		"infra:terraform-output": "node scripts/terraform-output.mjs",
		"infra:render-wrangler": "node scripts/render-wrangler-config.mjs --base infra/wrangler.template.jsonc --tf-json infra/out/terraform.tf.json",
		"infra:provision": "node scripts/provision-env.mjs"
	},
	"dependencies": {
		"@eetr/react-reducer-utils": "^0.1.1",
		"@opennextjs/cloudflare": "^1.17.1",
		"@scalar/nextjs-api-reference": "^0.10.6",
		"@simplewebauthn/browser": "^9.0.1",
		"jose": "^6.0.11",
		"lucide-react": "^0.576.0",
		"md5": "^2.3.0",
		"next": "16.1.5",
		"next-auth": "^5.0.0-beta.30",
		"react": "19.1.5",
		"react-dom": "19.1.5",
		"resend": "^6.9.4"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@simplewebauthn/server": "^9.0.3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20.19.35",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"@vitest/coverage-v8": "^4.1.2",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"strip-json-comments": "^5.0.1",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"vitest": "^4.1.2",
		"wrangler": "^4.69.0"
	}
}
